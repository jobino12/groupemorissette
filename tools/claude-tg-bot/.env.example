# Get from @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to talk to the bot.
# Get yours by messaging @userinfobot on Telegram.
ALLOWED_USER_IDS=

# Default working directory for new Claude sessions. Override per-chat with /cd.
DEFAULT_CWD=/Users/sam/code

# Optional. Where SQLite + logs live. Defaults to ./data
DATA_DIR=./data

# --- Voice (fully free, all local) ---
# Whisper.cpp model file. Downloaded during BOOTSTRAP step 2 (voice).
# Default: <DATA_DIR>/models/ggml-small.bin
# WHISPER_MODEL_PATH=

# macOS `say` voices for the bot (bilingual). Detected automatically per reply.
# Run `say -v ?` on the iMac to list all installed voices.
#   French male defaults: Thomas (fr-FR, built-in). Felix (fr-CA, Premium, download via System Settings).
#   English male defaults: Daniel (en-GB, built-in). Steve / Aaron / Tom (en-US, Premium options).
TTS_VOICE_FR=Thomas
TTS_VOICE_EN=Daniel

# --- Usage notifier ---
# Approximate caps used for rate-limit notifications (Anthropic doesn't publish
# exact numbers, so these are tunable). Defaults are rough Max-tier guidance.
# You'll get a Telegram message at every additional 10% crossed in each window.
MAX_5H_TURNS=225
MAX_WEEKLY_TURNS=2000
# Hard stop: the bot refuses NEW requests once either window reaches this % of
# its cap, to protect your Max quota. Default 90. Raise if you find it too eager.
HARD_STOP_PCT=90
# Chat that receives usage notifications. Defaults to the first ALLOWED_USER_IDS entry.
# NOTIFICATIONS_CHAT_ID=

# DO NOT set ANTHROPIC_API_KEY here. The Agent SDK will fall back to your
# `claude login` OAuth credentials so usage hits your Max subscription
# instead of API billing.

# --- Model routing ---
# Fast/conversational model used for interactive chat (voice + text).
# Sonnet is snappy enough for back-and-forth and works well for voice.
CHAT_MODEL=claude-sonnet-4-6

# Heavy model used for /opus and all scheduled jobs (where latency doesn't
# matter and you want depth: scraping, modeling, deck generation).
HEAVY_MODEL=claude-opus-4-7

# --- Project-specific credentials Claude can use during tool calls ---
# Reprenariat Québec (paid account) — Playwright logs in with these when
# the bot asks Claude to check the platform.
REPRENARIAT_QC_EMAIL=
REPRENARIAT_QC_PASSWORD=
