{
  "name": "groupemorissette",
  "private": true,
  "version": "0.0.0",
  "description": "Groupe Morissette ERP — monorepo (marketing site + web ERP + mobile + shared packages)",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @gm/db generate",
    "db:migrate": "pnpm --filter @gm/db migrate",
    "web": "pnpm --filter @gm/web dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.2",
      "@types/react-dom": "19.0.2"
    }
  }
}
